{
  "name": "temp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare:python": "node -e \"const{execSync}=require('child_process');const p=process.platform==='win32'?'powershell -ExecutionPolicy Bypass -File src-tauri/scripts/prepare-python-runtime.ps1':'bash src-tauri/scripts/prepare-python-runtime.sh';execSync(p,{stdio:'inherit'})\"",
    "prepare:ffmpeg": "node -e \"const{execSync}=require('child_process');const p=process.platform==='win32'?'powershell -ExecutionPolicy Bypass -File src-tauri/scripts/prepare-ffmpeg.ps1':'bash src-tauri/scripts/prepare-ffmpeg.sh';execSync(p,{stdio:'inherit'})\"",
    "prepare:all": "npm run prepare:python && npm run prepare:ffmpeg"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@types/marked": "^5.0.2",
    "cloakbrowser": "^0.3.30",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.4",
    "playwright": "^1.60.0",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
