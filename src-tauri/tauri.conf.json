{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoCast AI",
  "version": "0.1.0",
  "identifier": "com.make.autocast",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AutoCast AI",
        "width": 1280,
        "height": 800,
        "resizable": false,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; media-src 'self' asset: http://asset.localhost https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$LOCALAPPDATA/AutoCastAI/scraper_data/**",
          "$LOCALAPPDATA/AutoCastAI/video_studio/**",
          "$APPDATA/AutoCastAI/scraper_data/**",
          "$APPDATA/AutoCastAI/video_studio/**",
          "$DATA/AutoCastAI/scraper_data/**",
          "$DATA/AutoCastAI/video_studio/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../scripts/*.py",
      "../scripts/*.json",
      "../scripts/static/*",
      "../scripts/video_providers/*.py",
      "../scripts/image_providers/*.py",
      "../scripts/tts_providers/*.py",
      "../scripts/DouyinComment/*.py",
      "../scripts/DouyinComment/*.yaml",
      "../scripts/DouyinComment/*.txt",
      "../scripts/DouyinComment/core/**/*",
      "../scripts/DouyinComment/services/**/*",
      "../scripts/DouyinComment/utils/**/*",
      "../scripts/DouyinComment/scripts/**/*",
      "../scripts/DouyinBarrage/*.py",
      "../scripts/DouyinBarrage/*.yaml",
      "../scripts/DouyinBarrage/*.js",
      "../scripts/DouyinBarrage/*.txt",
      "../scripts/DouyinBarrage/base/**/*",
      "../scripts/DouyinBarrage/service/**/*",
      "../scripts/DouyinBarrage/scripts/**/*",
      "python-runtime/macos/python/**/*",
      "ffmpeg-runtime/macos/**/*"
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN", "en-US"]
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
